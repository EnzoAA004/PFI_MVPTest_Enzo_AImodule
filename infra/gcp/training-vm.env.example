# Contrato de variables para la VM de entrenamiento final PFI.
# Compatible con Bash:
#   set -a
#   source infra/gcp/training-vm.env.example
#   set +a
#
# Este archivo no contiene secretos, tokens, passwords ni claves JSON.
# Copiar a training-vm.env para ajustes locales. training-vm.env no se commitea.

# ==================================================
# A - Google Cloud
# ==================================================
# Estas variables NO son credenciales.
# La VM usara la cuenta de servicio adjunta:
# pfi-training-vm@pfi-asplanatti-fabrello-v1.iam.gserviceaccount.com
# No descargar ni commitear claves JSON. No usar tokens en este archivo.
# Los prefijos GCS pueden contener subdirectorios por corrida en commits posteriores.
PFI_GCP_PROJECT_ID=pfi-asplanatti-fabrello-v1
PFI_GCP_REGION=us-central1
PFI_GCP_ZONE=us-central1-a
PFI_VM_NAME=pfi-training-t4-v1
# PFI_VM_SERVICE_ACCOUNT es un identificador, no una credencial.
PFI_VM_SERVICE_ACCOUNT=pfi-training-vm@pfi-asplanatti-fabrello-v1.iam.gserviceaccount.com

PFI_GCS_BUCKET=pfi-rm-lumbar-artifacts-2026-ef
PFI_GCS_BUCKET_URI=gs://pfi-rm-lumbar-artifacts-2026-ef

PFI_GCS_DATASETS_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/datasets
# Estructura esperada: datasets/SPIDER, datasets/AXIAL_ALKAFRI, datasets/metadata y datasets/bootstrap_models.
PFI_GCS_SPIDER_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/datasets/SPIDER
PFI_GCS_AXIAL_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/datasets/AXIAL_ALKAFRI
PFI_GCS_METADATA_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/datasets/metadata
PFI_GCS_BOOTSTRAP_MODELS_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/datasets/bootstrap_models
PFI_GCS_MODELS_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/models
PFI_GCS_RESUME_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/resume
PFI_GCS_MANIFESTS_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/manifests
PFI_GCS_OUTPUTS_URI=gs://pfi-rm-lumbar-artifacts-2026-ef/outputs

# ==================================================
# B - Rutas locales de la VM
# ==================================================
# Los datasets se entrenaran desde disco local, no directamente contra GCS.
# El bucket se usara como persistencia para datasets, resume y resultados.
# Detener la VM conserva el disco. Borrar la VM elimina el disco porque autoDelete esta habilitado.
# Nunca borrar la VM antes de verificar la sincronizacion de artifacts a GCS.
PFI_VM_ROOT=/opt/pfi
PFI_REPO_URL=https://github.com/EnzoAA004/PFI_MVPTest_Enzo_AImodule.git
PFI_REPO_ROOT=/opt/pfi/PFI_MVPTest_Enzo_AImodule
PFI_DATA_ROOT=/opt/pfi/data
PFI_OUTPUT_ROOT=/opt/pfi/outputs
PFI_TRAIN_OUTPUT_DIR=/opt/pfi/outputs/final_training
PFI_LOCAL_RESUME_DIR=/opt/pfi/outputs/final_training/resume
PFI_LOCAL_MODELS_DIR=/opt/pfi/outputs/final_training/models
PFI_LOCAL_MANIFESTS_DIR=/opt/pfi/outputs/final_training/manifests
PFI_LOCAL_LOGS_DIR=/opt/pfi/outputs/final_training/logs
# PFI_PYTHON_BIN debe apuntar al Python de la imagen Deep Learning VM.
PFI_PYTHON_BIN=python3
# El entorno virtual se crea con --system-site-packages para reutilizar PyTorch/CUDA preinstalado.
# El script no debe reinstalar ni actualizar torch o torchvision.
PFI_VENV_DIR=/opt/pfi/venv
# Umbral minimo de seguridad; no estima el tamano final requerido del entrenamiento.
PFI_MIN_FREE_DISK_GB=20

# ==================================================
# C - Estructura local esperada de SPIDER
# ==================================================
# El JSON de mapping es la fuente preferida.
# El checkpoint auxiliar es solo fallback para recuperar label_group_mapping.
# La existencia real sera comprobada por el futuro preflight.
SPIDER_IMAGES_DIR=/opt/pfi/data/SPIDER/images
SPIDER_MASKS_DIR=/opt/pfi/data/SPIDER/masks
SPIDER_LABEL_GROUP_MAPPING_JSON=/opt/pfi/data/metadata/E5_multiclass_label_mapping.json
SPIDER_CHECKPOINT_FOR_LABEL_MAP=/opt/pfi/data/bootstrap_models/sagittal_spider_multiclass_final_best.pt
SPIDER_SAGITTAL_AXIS=2

# ==================================================
# D - Estructura local esperada de AXIAL_ALKAFRI
# ==================================================
# Todavia debe confirmarse si el CSV contiene paths absolutos de Google Drive.
# El futuro notebook v5 debera rebasar o normalizar esos paths.
# No resolver ese problema en esta tarea.
AXIAL_E9_CURATED_SPLIT_CSV=/opt/pfi/data/metadata/E9_t2_final_labels_curated_split.csv
AXIAL_IMAGES_DIR=/opt/pfi/data/AXIAL_ALKAFRI
AXIAL_MASKS_DIR=/opt/pfi/data/AXIAL_ALKAFRI
AXIAL_IMAGE_COL=image_file_path
AXIAL_MASK_COL=final_label_file_path
AXIAL_PATIENT_COL=case_id_norm
AXIAL_SPLIT_COL=split
AXIAL_RAW_PAIRING_MODE=0
AXIAL_RAW0_WEIGHT_BOOST=3.0

# ==================================================
# E - Entrenamiento final
# ==================================================
# Identidad estable de corrida. Cambiar explicitamente para una corrida nueva.
# Regex permitido: ^[a-z0-9][a-z0-9-]{0,62}$
PFI_RUN_ID=pfi-final-training-v1
# Prefijos derivados al hacer source; separan artifacts por corrida y nunca apuntan a la raiz del bucket.
PFI_GCS_RUN_MODELS_URI="${PFI_GCS_MODELS_URI}/${PFI_RUN_ID}"
PFI_GCS_RUN_RESUME_URI="${PFI_GCS_RESUME_URI}/${PFI_RUN_ID}"
PFI_GCS_RUN_MANIFESTS_URI="${PFI_GCS_MANIFESTS_URI}/${PFI_RUN_ID}"
PFI_GCS_RUN_OUTPUTS_URI="${PFI_GCS_OUTPUTS_URI}/${PFI_RUN_ID}"
# REQUIRE_GPU=1 evita entrenamiento final accidental en CPU.
# PFI_SMOKE_RUN=0 corresponde a la corrida final.
# PFI_RESUME_TRAINING=1 mantiene reanudacion entre inicios de VM.
# No modificar hiperparametros sin documentarlo.
# La primera VM tiene duracion maxima de 12 horas por cada inicio.
REQUIRE_GPU=1
RUN_SAGITTAL=1
RUN_AXIAL=1
PFI_SMOKE_RUN=0
PFI_RESUME_TRAINING=1
PFI_RESUME_DIR=resume
PFI_BASE_CHANNELS=16
PFI_BATCH_SIZE=8
PFI_MAX_EPOCHS=80
PFI_EARLY_STOP_PATIENCE=12
PFI_LR=0.0008
PFI_SEED=20260716
PFI_NUM_WORKERS=0
PFI_WEIGHT_MAX_RECORDS=128
PFI_LOG_EVERY_N_BATCHES=25

# ==================================================
# F - Flags futuros de operacion cloud
# ==================================================
# Todavia no son consumidos por el notebook v4.
# Seran utilizados por scripts y notebook v5 en commits posteriores.
# No implementar su logica en este commit.
PFI_PREFLIGHT_ONLY=0
PFI_SYNC_DRY_RUN=1
PFI_DOWNLOAD_DATASETS=1
# Permite restaurar checkpoints previos de la corrida actual.
PFI_DOWNLOAD_RESUME=1
PFI_SYNC_RESUME=1
PFI_SYNC_FINAL_ARTIFACTS=1
# Default seguro: PFI_SYNC_DRY_RUN=1 y, ademas, los scripts requieren --execute para transferir.
# Evita copiar archivos que podrian seguir escribiendose; notebook v5 debera guardar atomico.
PFI_SYNC_MIN_FILE_AGE_SECONDS=10
